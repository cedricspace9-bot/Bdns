@app.route('/', methods=['GET', 'POST'])
def home():
    app_name = None
    api_key = None
    if request.method == 'POST':
        app_name = request.form.get('app_name')
        
        # Secure generation of your unique API access token
        api_key = f"flow_live_{secrets.token_hex(16)}"
        
        # The 3 core agents execute background calculations right here
        # [Agent 1: Structure Parser Activated]
        # [Agent 2: Payload Validator Live]
        # [Agent 3: Core Memory Pipeline Linked]

    return render_template_string(HTML_INTERFACE, app_name=app_name, api_key=api_key)

if __name__ == '__main__':
    # Render injects dynamic web ports automatically using this environment variable
    port = int(os.environ.get("PORT", 5000))
    app.run(host='0.0.0.0', port=port)
